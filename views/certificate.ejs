<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INNOVEX-2.O | E-Certificate</title>
    <meta name="description" content="Download your INNOVEX 2.0 e-certificate">
    <link rel="stylesheet" href="/styles/main.css">
    <style>
        .cert-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .cert-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2em;
        }
        .cert-form-box {
            background: rgba(0, 243, 255, 0.04);
            border: 1px solid rgba(0, 243, 255, 0.2);
            backdrop-filter: blur(8px);
            padding: 3em 4em;
            text-align: center;
            max-width: 500px;
            width: 100%;
            clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);
        }
        .cert-form-box h1 {
            font-family: var(--font-baron);
            color: #fff;
            margin-bottom: 0.5em;
            font-size: 2em;
            letter-spacing: 2px;
        }
        .cert-form-box p {
            font-family: var(--font-lexend);
            color: var(--cyon-color);
            margin-bottom: 2em;
            font-size: 0.9em;
            line-height: 1.5;
        }
        .cert-form-box form {
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 1em;
        }
        .cert-form-box input {
            width: 100%;
            padding: 1em;
            margin: 0;
            background: rgba(0, 255, 255, 0.05);
            border: 1px solid rgba(0, 243, 255, 0.3);
            color: #fff;
            font-family: var(--font-jetbrains);
            outline: none;
            transition: border-color 0.3s;
        }
        .cert-form-box input:focus {
            border-color: rgba(0, 243, 255, 0.8);
        }
        .cert-form-box input::placeholder {
            color: rgba(255,255,255,0.4);
        }
        .cert-form-box .btn-primary {
            width: 100%;
            margin-top: 1em;
            padding: 1em;
            background: var(--cyon-color);
            color: #000;
            border: none;
            font-family: var(--font-jetbrains);
            font-weight: bold;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }
        .cert-form-box .btn-primary:hover {
            background: #00cccc;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.4);
        }
        .error-msg {
            color: #ff6b35;
            background: rgba(255, 107, 53, 0.1);
            border: 1px solid rgba(255, 107, 53, 0.3);
            padding: 1em;
            font-family: var(--font-jetbrains);
            font-size: 0.85em;
            margin-bottom: 1.5em;
        }
    </style>
</head>

<body>
    <!-- GRID BG -->
    <div class="background-svg-container">
        <svg class="grid-layer" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="dashedGrid" width="18" height="18" patternTransform="scale(2)"
                    patternUnits="userSpaceOnUse">
                    <rect width="100%" height="100%" fill="#020408" />
                    <path d="M20 0H0v20" fill="none" stroke="#1e211d" stroke-width="0.8" stroke-dasharray="2,2" />
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dashedGrid)" />
        </svg>
    </div>

    <div class="cert-container">
        <%- include('partials/navbar', { currentPage: '/certificate' }) %>
        
        <div class="cert-content">
            <div class="cert-form-box">
                <h1>GET CERTIFICATE</h1>
                <p>Enter your registered email address to download e-certificates for your entire team.</p>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-msg"><%= error %></div>
                <% } %>

                <form action="/certificate/generate" method="POST">
                    <input type="email" name="email" placeholder="Registered Email Address" required>
                    <button type="submit" class="btn-primary">Download PDF</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
