<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INNOVEX-2.O ( Volunteer Login )</title>
    <link rel="stylesheet" href="/styles/main.css">

</head>

<body>
    <!-- GRID BG -->
    <div class="background-svg-container">
        <svg class="grid-layer" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="dashedGrid" width="18" height="18" patternTransform="scale(2)"
                    patternUnits="userSpaceOnUse">
                    <rect width="100%" height="100%" fill="#020408" />
                    <path d="M20 0H0v20" fill="none" stroke="#1e211d" stroke-width="0.8" stroke-dasharray="2,2" />
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dashedGrid)" />
        </svg>
    </div>


    <!-- MAIN -->
    <main class="main">
        <%- include('partials/navbar') %>

            <div class="container">
                <div class="content login-content">
                    <h1>Volunteer Login</h1>

                    <!-- Form -->
                    <form id="loginForm">

                        <input type="text" placeholder="UID" name="uid" required>

                        <input type="password" placeholder="Password" name="password" required>

                        <button type="submit" class="btn-primary">LOGIN</button>

                    </form>

                    <p class="footer-note">MADE WITH 💖 BY : <a href="https://ankith.dev">ANKITH</a></p>

                </div>
            </div>
    </main>

    <script src="/scripts/main.js"></script>
</body>

</html>