<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INNOVEX-2.O | Dashboard</title>
    <meta name="description" content="Volunteer dashboard for INNOVEX 2.0 event management">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/dashboard.css">
</head>

<body>
    <!-- GRID BG -->
    <div class="background-svg-container">
        <svg class="grid-layer" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="dashedGrid" width="18" height="18" patternTransform="scale(2)"
                    patternUnits="userSpaceOnUse">
                    <rect width="100%" height="100%" fill="#020408" />
                    <path d="M20 0H0v20" fill="none" stroke="#1e211d" stroke-width="0.8" stroke-dasharray="2,2" />
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dashedGrid)" />
        </svg>
    </div>

    <!-- Embed server data for the client script -->
    <script>
        const SERVER_DATA = {
            uid: "<%- uid %>",
            event: "<%- event %>",
            isAdmin: <%- isAdmin %>,
            registrations: <%- registrations %>,
            allEvents: <%- allEvents %>,
            totalCount: <%- totalCount %>
        };
    </script>

    <!-- MAIN -->
    <main class="main">
        <%- include('partials/navbar', { currentPage: '/dashboard' }) %>

        <div class="dashboard-wrapper">

            <!-- HEADER -->
            <div class="dashboard-header">
                <div class="dashboard-title-group">
                    <h1>DASHBOARD</h1>
                    <p class="dashboard-subtitle">
                        <% if (isAdmin) { %>
                            Welcome back, <strong><%= uid %></strong> — Admin Access
                        <% } else { %>
                            Welcome, <strong><%= uid %></strong> &mdash; Managing: <span class="event-tag"><%= event %></span>
                        <% } %>
                    </p>
                </div>
                <div class="dashboard-meta">
                    <% if (isAdmin) { %>
                        <span class="badge admin">⚡ Admin</span>
                    <% } else { %>
                        <span class="badge">🎯 <%= event %></span>
                    <% } %>
                </div>
            </div>

            <!-- STATS ROW -->
            <div class="stats-row">
                <div class="stat-card">
                    <span class="stat-number" id="totalCount">0</span>
                    <span class="stat-label">Total Registrations</span>
                </div>
                <div class="stat-card">
                    <span class="stat-number" id="eventCount">0</span>
                    <span class="stat-label"><%= isAdmin ? 'Unique Events' : 'In Your Event' %></span>
                </div>
                <div class="stat-card">
                    <span class="stat-number" id="teamCount">0</span>
                    <span class="stat-label">Teams</span>
                </div>
            </div>

            <!-- FILTER BAR (admin only) -->
            <% if (isAdmin) { %>
            <div class="filter-bar" id="filterBar">
                <select id="eventFilter">
                    <option value="all">All Events</option>
                    <% JSON.parse(allEvents).forEach(function(ev) { %>
                        <option value="<%= ev %>"><%= ev %></option>
                    <% }); %>
                </select>
                <input type="text" id="searchInput" placeholder="Search by name, college, team..." />
            </div>
            <% } %>

            <!-- TABLE -->
            <div class="table-container">
                <table id="registrationsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Event</th>
                            <th>Team / Members</th>
                            <th>College</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>UTR No.</th>
                            <th>Preview</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                    </tbody>
                </table>
            </div>

        </div>
    </main>

    <!-- STATUS MODAL -->
    <div class="modal-overlay" id="statusModal">
        <div class="modal-content status-modal-content">
            <p class="status-modal-name" id="statusModalName">—</p>
            <p class="status-modal-event" id="statusModalEvent">—</p>
            <div class="status-modal-actions">
                <button id="markPresentBtn" class="btn-status present">✅ Mark Present</button>
                <button id="markAbsentBtn"  class="btn-status absent">❌ Mark Absent</button>
            </div>
            <button class="btn-status-cancel" id="statusModalClose">Cancel</button>
        </div>
    </div>

    <script src="/scripts/dashboard.js"></script>
</body>

</html>
